<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <configSections>
    </configSections>
    <connectionStrings>
        <add name="SMS.Properties.Settings.School_Management_SystemConnectionString"
            connectionString="Data Source=.;Initial Catalog=School_Management_System;Integrated Security=True;Encrypt=False"
            providerName="System.Data.SqlClient" />
    </connectionStrings>
    <startup> 
