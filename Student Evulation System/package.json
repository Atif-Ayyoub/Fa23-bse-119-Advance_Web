{
  "name": "student-evaluation-system",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0",
    "exceljs": "^4.3.0",
    "lucide-react": "^0.575.0",
    "pdf-parse": "^1.1.1",
    "sql.js": "^1.8.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron": "^26.0.0",
    "electron-builder": "^23.6.0",
    "postcss": "^8.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.7",
    "vite": "^5.0.0",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.atif.student-evaluation",
    "productName": "Student Evaluation System",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/**"
    ],
    "asarUnpack": [
      "node_modules/sql.js/dist/sql-wasm.wasm"
    ],
    "extraResources": [
      {
        "from": "database.sqlite",
        "to": "database.sqlite"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
